# Copy to .env and fill in. All values are optional except DATABASE_URL in production.
# The frontend is built same-origin (VITE_API_URL unset), so it calls /api relatively.

# --- Database (required in production) ---
# Neon serverless Postgres connection string, e.g.
# postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# --- Server ---
PORT=8787
# Comma-separated list of front-end origins allowed to call the API. Usually unnecessary when
# the API and SPA share an origin (Vercel). Set to your domain if you ever call cross-origin.
CORS_ORIGIN=
# Public base URL the server reports (OAuth redirects, verify links). On Vercel this is derived
# from VERCEL_URL automatically; set only for a custom domain.
PUBLIC_URL=
# Front-end origin OAuth redirects back to. Derived from VERCEL_URL on Vercel; set for custom domain.
APP_URL=
# Token lifetimes
ACCESS_TTL_MIN=60
REFRESH_TTL_DAYS=30
# Set to 1 when behind a reverse proxy (Vercel sets this automatically via the VERCEL env).
TRUST_PROXY=0

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Email verification (optional; if set, signup requires verifying email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
