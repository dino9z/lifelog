# Copy to .env and fill in. All values are optional except where noted.
# The frontend is built same-origin (VITE_API_URL unset), so it calls /api relatively.

# --- Server ---
PORT=8787
# Comma-separated list of front-end origins allowed to call the API. REQUIRED in prod.
# Example: https://lifelog.example.com
CORS_ORIGIN=http://localhost:5173,http://localhost:4173,http://localhost:4184
# Public base URL the server reports (used for OAuth redirects).
PUBLIC_URL=http://localhost:8787
# Front-end origin OAuth redirects back to (must match where the app is served).
APP_URL=http://localhost:5173
# Optional: lock the session cookie to this origin (defaults to APP_URL). Set to your
# HTTPS domain in production, e.g. https://lifelog.example.com
SESSION_FROM=
# Token lifetimes
ACCESS_TTL_MIN=60
REFRESH_TTL_DAYS=30
# Set to 1 when behind a reverse proxy (nginx/Caddy/Traefik) so rate limits use the real client IP.
TRUST_PROXY=0

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Email verification (optional; if set, signup requires verifying email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
